{
  "permissions": {
    "allow": [
      "Bash(python3:*)",
      "Bash(git:*)",
      "Bash(command:*)",
      "Bash(xargs:*)",
      "Bash(find:*)"
    ],
    "defaultMode": "default"
  },
  "model": "opusplan",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/scripts/hooks/session_start.py",
            "timeout": 2,
            "statusMessage": "Loading framework context..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/scripts/hooks/user_prompt_submit.py",
            "timeout": 2
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/scripts/hooks/pre_tool_use.py",
            "timeout": 2
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/scripts/hooks/post_tool_use.py",
            "timeout": 2,
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/scripts/hooks/pre_compact.py",
            "timeout": 2,
            "statusMessage": "Saving session state before compaction..."
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/scripts/hooks/post_compact.py",
            "timeout": 2,
            "statusMessage": "Restoring session state..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/scripts/hooks/subagent_stop.py",
            "timeout": 2
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/scripts/hooks/stop.py",
            "timeout": 2
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/scripts/hooks/notification.py",
            "timeout": 2,
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 ~/.claude/scripts/statusline.py"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "context-framework@local": true
  },
  "extraKnownMarketplaces": {
    "local": {
      "source": {
        "source": "directory",
        "path": "/root/.claude/plugins/local"
      }
    }
  },
  "effortLevel": "medium",
  "voiceEnabled": true,
  "channelsEnabled": true
}
